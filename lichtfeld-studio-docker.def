Bootstrap: docker
From: plasmax7/lichtfeld-studio:latest

%labels
    Description Minimal Apptainer image for LichtFeld-Studio built on top of the DockerHub dev image

%help
    Build-time: clones and builds LichtFeld-Studio using the vcpkg checkout
    already present in the Docker base image.
    Runtime: launches the build-tree LichtFeld-Studio binary directly.

    Example launch (X11 + NVIDIA):
      apptainer run --cleanenv --nv \
        --bind /tmp/.X11-unix:/tmp/.X11-unix \
        --bind ${HOME}/.Xauthority:${HOME}/.Xauthority \
        --env DISPLAY=${DISPLAY} \
        --env XAUTHORITY=${HOME}/.Xauthority \
        lichtfeld_studio.sif

%environment
    export QT_X11_NO_MITSHM=1
    export VCPKG_ROOT=/home/ubuntu/vcpkg
    export PATH=/opt/LichtFeld-Studio/build:${PATH}
    export LD_LIBRARY_PATH=/opt/LichtFeld-Studio/build:/opt/LichtFeld-Studio/build/vcpkg_installed/x64-linux/lib:${LD_LIBRARY_PATH:-}

%post
    set -eu

    export VCPKG_ROOT=/home/ubuntu/vcpkg

    # The Docker base image should already provide the full build toolchain.
    command -v git >/dev/null 2>&1
    command -v cmake >/dev/null 2>&1
    if ! command -v ninja >/dev/null 2>&1 && command -v ninja-build >/dev/null 2>&1; then
        ln -s "$(command -v ninja-build)" /usr/local/bin/ninja
    fi
    command -v ninja >/dev/null 2>&1
    test -x "${VCPKG_ROOT}/vcpkg"

    # Source checkout + build
    git clone --depth 1 --recursive --shallow-submodules https://github.com/MrNeRF/LichtFeld-Studio /opt/LichtFeld-Studio

    cmake -S /opt/LichtFeld-Studio -B /opt/LichtFeld-Studio/build \
        -G Ninja \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_TOOLCHAIN_FILE=${VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake \
        -DBUILD_PYTHON_STUBS=OFF

    cmake --build /opt/LichtFeld-Studio/build --parallel "$(nproc)"

    test -x /opt/LichtFeld-Studio/build/LichtFeld-Studio
    mkdir -p /usr/local/bin
    ln -sf /opt/LichtFeld-Studio/build/LichtFeld-Studio /usr/local/bin/lichtfeld-studio

%runscript
    export QT_X11_NO_MITSHM=${QT_X11_NO_MITSHM:-1}
    exec /usr/local/bin/lichtfeld-studio "$@"

%test
    set -eu
    test -x /usr/local/bin/lichtfeld-studio
    test -x /opt/LichtFeld-Studio/build/LichtFeld-Studio
    ldd /opt/LichtFeld-Studio/build/LichtFeld-Studio >/dev/null
    command -v python3 >/dev/null
