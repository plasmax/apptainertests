Bootstrap: docker
From: plasmax7/lichtfeld-studio:latest

%labels
    Description Apptainer image for LichtFeld-Studio built from source on top of the upstream Docker dev environment

%help
    Build-time: clones and builds LichtFeld-Studio with CMake + vcpkg.
    Runtime: launches LichtFeld-Studio binary.

    Example launch (X11 + NVIDIA):
      uid=$(id -u)
      apptainer run --cleanenv --nv \
        --bind /tmp/.X11-unix:/tmp/.X11-unix \
        --bind /run/user/${uid}:/run/user/${uid} \
        --bind ${HOME}/.Xauthority:${HOME}/.Xauthority \
        --env DISPLAY=${DISPLAY} \
        --env XAUTHORITY=${HOME}/.Xauthority \
        lichtfeld_studio_docker.sif

%environment
    export QT_X11_NO_MITSHM=1
    export PATH=/opt/lichtfeld/bin:${PATH}
    export LD_LIBRARY_PATH=/opt/lichtfeld/lib:/opt/lichtfeld/lib64:/opt/LichtFeld-Studio/build/vcpkg_installed/x64-linux/lib:${LD_LIBRARY_PATH:-}

%post
    set -eu

    export DEBIAN_FRONTEND=noninteractive

    # Ensure core tooling is available in case base image drifts.
    apt-get update
    apt-get install -y --no-install-recommends \
        ca-certificates \
        git \
        ninja-build \
        pkg-config \
        python3
    rm -rf /var/lib/apt/lists/*

    if ! command -v ninja >/dev/null 2>&1 && command -v ninja-build >/dev/null 2>&1; then
        ln -sf "$(command -v ninja-build)" /usr/local/bin/ninja
    fi

    # Prefer vcpkg provided by Docker image; fallback to local clone if absent.
    if [ -d /home/ubuntu/vcpkg ]; then
        export VCPKG_ROOT=/home/ubuntu/vcpkg
    else
        git clone --depth 1 https://github.com/microsoft/vcpkg.git /opt/vcpkg
        /opt/vcpkg/bootstrap-vcpkg.sh -disableMetrics
        export VCPKG_ROOT=/opt/vcpkg
    fi

    # Clone and build LichtFeld-Studio.
    git clone --depth 1 --recursive https://github.com/MrNeRF/LichtFeld-Studio /opt/LichtFeld-Studio

    cmake -S /opt/LichtFeld-Studio -B /opt/LichtFeld-Studio/build \
        -G Ninja \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_TOOLCHAIN_FILE=${VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake \
        -DBUILD_PYTHON_STUBS=OFF

    cmake --build /opt/LichtFeld-Studio/build --parallel "$(nproc)"

    # Install if upstream install target exists; otherwise link built binary directly.
    mkdir -p /opt/lichtfeld/bin /usr/local/bin
    if cmake --install /opt/LichtFeld-Studio/build --prefix /opt/lichtfeld; then
        :
    elif [ -x /opt/LichtFeld-Studio/build/LichtFeld-Studio ]; then
        ln -sf /opt/LichtFeld-Studio/build/LichtFeld-Studio /opt/lichtfeld/bin/LichtFeld-Studio
    else
        echo "ERROR: build succeeded but LichtFeld-Studio binary was not found" >&2
        exit 1
    fi

    if [ -x /opt/lichtfeld/bin/LichtFeld-Studio ]; then
        ln -sf /opt/lichtfeld/bin/LichtFeld-Studio /usr/local/bin/lichtfeld-studio
    elif [ -x /opt/LichtFeld-Studio/build/LichtFeld-Studio ]; then
        ln -sf /opt/LichtFeld-Studio/build/LichtFeld-Studio /usr/local/bin/lichtfeld-studio
    else
        echo "ERROR: unable to create launcher; binary missing" >&2
        exit 1
    fi

%runscript
    export QT_X11_NO_MITSHM=${QT_X11_NO_MITSHM:-1}
    exec /usr/local/bin/lichtfeld-studio "$@"

%test
    set -eu
    test -x /usr/local/bin/lichtfeld-studio
    command -v python3 >/dev/null
    command -v gcc >/dev/null
    ldd /usr/local/bin/lichtfeld-studio >/dev/null
