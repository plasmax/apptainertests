Bootstrap: docker
From: rockylinux:9

%labels
    Description EL9 Apptainer image for LichtFeld Studio built from source with vcpkg

%environment
    export GCC_TOOLSET_ROOT=/opt/rh/gcc-toolset-14/root/usr
    export PATH=${GCC_TOOLSET_ROOT}/bin:/opt/lichtfeld/bin:/usr/local/cuda/bin:$PATH
    export LD_LIBRARY_PATH=${GCC_TOOLSET_ROOT}/lib64:/opt/lichtfeld/lib64:/opt/lichtfeld/lib:/opt/LichtFeld-Studio/build/vcpkg_installed/x64-linux/lib:/usr/local/cuda/lib64:${LD_LIBRARY_PATH:-}
    export VCPKG_ROOT=/opt/vcpkg
    export QT_X11_NO_MITSHM=1
    # Recover the host user bus under --cleanenv when /run/user/$UID is bound in.
    uid="$(id -u)"
    if [ -z "${XDG_RUNTIME_DIR:-}" ] && [ -d "/run/user/${uid}" ]; then
        export XDG_RUNTIME_DIR=/run/user/${uid}
    fi
    if [ -z "${DBUS_SESSION_BUS_ADDRESS:-}" ]; then
        runtime_dir="${XDG_RUNTIME_DIR:-/run/user/${uid}}"
        if [ -S "${runtime_dir}/bus" ]; then
            export DBUS_SESSION_BUS_ADDRESS=unix:path=${runtime_dir}/bus
        fi
    fi


%help
    Run with NVIDIA + X11 passthrough, for example:
      uid=$(id -u)
      apptainer run --cleanenv --nv \
        --bind /tmp/.X11-unix:/tmp/.X11-unix \
        --bind /run/user/${uid}:/run/user/${uid} \
        --bind ${HOME}/.Xauthority:${HOME}/.Xauthority \
        --env DISPLAY=${DISPLAY} \
        --env XAUTHORITY=${HOME}/.Xauthority \
        --env SDL_VIDEODRIVER=x11 \
        lichtfeld_studio_el9.sif

%post
    set -eu

    dnf -y update
    dnf -y install dnf-plugins-core epel-release

    # Enable CRB for development packages on EL9
    dnf config-manager --set-enabled crb
    dnf config-manager --add-repo https://developer.download.nvidia.com/compute/cuda/repos/rhel9/x86_64/cuda-rhel9.repo

    dnf -y install \
        gcc \
        gcc-c++ \
        gcc-toolset-14-gcc \
        gcc-toolset-14-gcc-c++ \
        gcc-toolset-14-gcc-gfortran \
        make \
        nasm \
        autoconf \
        autoconf-archive \
        automake \
        libtool \
        git \
        zip \
        unzip \
        tar \
        pkgconf-pkg-config \
        perl \
        python3 \
        python3-pip \
        which \
        file \
        xdg-utils \
        mesa-libGL \
        mesa-libGL-devel \
        mesa-libGLU-devel \
        mesa-libEGL \
        mesa-libEGL-devel \
        libglvnd-devel \
        libX11 \
        libX11-devel \
        libXext \
        libXext-devel \
        libXft \
        libXft-devel \
        libXrender-devel \
        libXrandr \
        libXrandr-devel \
        libXinerama \
        libXinerama-devel \
        libXcursor \
        libXcursor-devel \
        libXi \
        libXi-devel \
        libXfixes-devel \
        libXScrnSaver-devel \
        libXtst-devel \
        wayland-devel \
        wayland-protocols-devel \
        ibus \
        ibus-devel \
        libxkbcommon \
        libxkbcommon-devel \
        libxcb \
        libxcb-devel \
        xcb-util \
        xcb-util-devel \
        xcb-util-image \
        xcb-util-image-devel \
        xcb-util-keysyms \
        xcb-util-keysyms-devel \
        xcb-util-renderutil \
        xcb-util-renderutil-devel \
        xcb-util-wm \
        xcb-util-wm-devel \
        cuda-toolkit-12-8


    # Rocky/RHEL package naming differs across mirrors; support both variants.
    if ! dnf -y install ninja-build; then
        dnf -y install ninja
    fi
    if ! command -v ninja >/dev/null 2>&1 && command -v ninja-build >/dev/null 2>&1; then
        ln -sf "$(command -v ninja-build)" /usr/local/bin/ninja
    fi

    export GCC_TOOLSET_ROOT=/opt/rh/gcc-toolset-14/root/usr
    export PATH="${GCC_TOOLSET_ROOT}/bin:/usr/local/bin:/usr/local/cuda/bin:$PATH"
    export LD_LIBRARY_PATH="${GCC_TOOLSET_ROOT}/lib64:${LD_LIBRARY_PATH:-}"
    export CC="${GCC_TOOLSET_ROOT}/bin/gcc"
    export CXX="${GCC_TOOLSET_ROOT}/bin/g++"
    export FC="${GCC_TOOLSET_ROOT}/bin/gfortran"
    export CUDAHOSTCXX="${GCC_TOOLSET_ROOT}/bin/g++"

    curl -fsSL https://ftp.gnu.org/gnu/autoconf/autoconf-2.71.tar.gz -o /var/tmp/autoconf-2.71.tar.gz
    tar -xf /var/tmp/autoconf-2.71.tar.gz -C /var/tmp
    cd /var/tmp/autoconf-2.71
    ./configure --prefix=/usr/local
    make -j"$(nproc)"
    make install
    cd /
    rm -rf /var/tmp/autoconf-2.71 /var/tmp/autoconf-2.71.tar.gz
    export PATH="${GCC_TOOLSET_ROOT}/bin:/usr/local/bin:/usr/local/cuda/bin:$PATH"

    python3 -m pip install --no-cache-dir "cmake>=3.30,<4"

    dnf clean all
    rm -rf /var/cache/dnf

    git clone https://github.com/microsoft/vcpkg.git /opt/vcpkg
    if [ -n "${VCPKG_DOWNLOADS:-}" ]; then
        mkdir -p "$VCPKG_DOWNLOADS"
    fi
    if [ -n "${VCPKG_DEFAULT_BINARY_CACHE:-}" ]; then
        mkdir -p "$VCPKG_DEFAULT_BINARY_CACHE"
    fi
    /opt/vcpkg/bootstrap-vcpkg.sh -disableMetrics

    git clone --depth 1 --recursive https://github.com/MrNeRF/LichtFeld-Studio /opt/LichtFeld-Studio

    export VCPKG_ROOT=/opt/vcpkg
    cmake -S /opt/LichtFeld-Studio -B /opt/LichtFeld-Studio/build \
        -G Ninja \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_C_COMPILER="${GCC_TOOLSET_ROOT}/bin/gcc" \
        -DCMAKE_CXX_COMPILER="${GCC_TOOLSET_ROOT}/bin/g++" \
        -DCMAKE_CUDA_COMPILER=/usr/local/cuda/bin/nvcc \
        -DCMAKE_CUDA_HOST_COMPILER="${GCC_TOOLSET_ROOT}/bin/g++" \
        -DCMAKE_CUDA_ARCHITECTURES=86 \
        -DCMAKE_BUILD_RPATH="/opt/LichtFeld-Studio/build:/opt/rh/gcc-toolset-14/root/usr/lib64:/opt/LichtFeld-Studio/build/vcpkg_installed/x64-linux/lib:/usr/local/cuda/lib64:/usr/local/cuda-12.8/targets/x86_64-linux/lib" \
        -DCMAKE_INSTALL_RPATH="\$ORIGIN:\$ORIGIN/../lib64:\$ORIGIN/../lib:/opt/rh/gcc-toolset-14/root/usr/lib64:/opt/LichtFeld-Studio/build/vcpkg_installed/x64-linux/lib:/usr/local/cuda/lib64:/usr/local/cuda-12.8/targets/x86_64-linux/lib" \
        -DCMAKE_INSTALL_RPATH_USE_LINK_PATH=ON \
        -DBUILD_PYTHON_STUBS=OFF \
        -DCMAKE_TOOLCHAIN_FILE=/opt/vcpkg/scripts/buildsystems/vcpkg.cmake

    cmake --build /opt/LichtFeld-Studio/build --parallel "$(nproc)"
    cmake --install /opt/LichtFeld-Studio/build --prefix /opt/lichtfeld
    # Upstream install currently skips this runtime-loaded library.
    install -Dpm755 /opt/LichtFeld-Studio/build/liblfs_rmlui.so /opt/lichtfeld/lib64/liblfs_rmlui.so
    # Upstream runtime search assumes ../lib/python, but EL9 installs to lib64/python.
    mkdir -p /opt/lichtfeld/lib
    ln -sfn ../lib64/python /opt/lichtfeld/lib/python

    ln -sf /opt/LichtFeld-Studio/build/LichtFeld-Studio /usr/local/bin/lichtfeld-studio

%runscript
    export QT_X11_NO_MITSHM=${QT_X11_NO_MITSHM:-1}
    export GCC_TOOLSET_ROOT=${GCC_TOOLSET_ROOT:-/opt/rh/gcc-toolset-14/root/usr}
    export LD_LIBRARY_PATH=${GCC_TOOLSET_ROOT}/lib64:/opt/lichtfeld/lib64:/opt/lichtfeld/lib:/opt/LichtFeld-Studio/build/vcpkg_installed/x64-linux/lib:/usr/local/cuda/lib64:${LD_LIBRARY_PATH:-}
    uid="$(id -u)"
    if [ -z "${XDG_RUNTIME_DIR:-}" ] && [ -d "/run/user/${uid}" ]; then
        export XDG_RUNTIME_DIR=/run/user/${uid}
    fi
    if [ -z "${DBUS_SESSION_BUS_ADDRESS:-}" ]; then
        runtime_dir="${XDG_RUNTIME_DIR:-/run/user/${uid}}"
        if [ -S "${runtime_dir}/bus" ]; then
            export DBUS_SESSION_BUS_ADDRESS=unix:path=${runtime_dir}/bus
        fi
    fi
    exec /opt/lichtfeld/bin/LichtFeld-Studio "$@"

%test
    set -eu
    test -x /opt/LichtFeld-Studio/build/LichtFeld-Studio
    test -x /opt/lichtfeld/bin/LichtFeld-Studio
    ldd /opt/LichtFeld-Studio/build/LichtFeld-Studio >/dev/null
    env -i PATH=/usr/bin:/bin ldd /opt/lichtfeld/bin/LichtFeld-Studio >/dev/null
    test -e /opt/lichtfeld/lib64/liblfs_rmlui.so -o -e /opt/lichtfeld/lib/liblfs_rmlui.so
    test -d /opt/lichtfeld/lib/python/lfs_plugins
    find /opt/lichtfeld/lib/python -maxdepth 1 -name 'lichtfeld*.so' | grep -q .
    command -v xdg-open >/dev/null
    ar t /opt/LichtFeld-Studio/build/vcpkg_installed/x64-linux/lib/libSDL3.a | grep -Eq 'x11|wayland'
