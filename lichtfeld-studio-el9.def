Bootstrap: docker
From: rockylinux:9

%labels
    Description EL9 Apptainer image for LichtFeld Studio built from source with vcpkg

%environment
    export GCC_TOOLSET_ROOT=/opt/rh/gcc-toolset-14/root/usr
    export PATH=${GCC_TOOLSET_ROOT}/bin:/opt/lichtfeld/bin:/usr/local/cuda/bin:$PATH
    # Upstream install misses some runtime libs, so keep the build tree on the runtime search path.
    export LD_LIBRARY_PATH=${GCC_TOOLSET_ROOT}/lib64:/opt/LichtFeld-Studio/build:/opt/lichtfeld/lib64:/opt/lichtfeld/lib:/usr/local/cuda/lib64:${LD_LIBRARY_PATH:-}
    export VCPKG_ROOT=/opt/vcpkg
    export QT_X11_NO_MITSHM=1


%help
    Run with NVIDIA + X11 passthrough, for example:
      apptainer run --cleanenv --nv \
        --bind /tmp/.X11-unix:/tmp/.X11-unix \
        --bind ${HOME}/.Xauthority:${HOME}/.Xauthority \
        --env DISPLAY=${DISPLAY} \
        --env XAUTHORITY=${HOME}/.Xauthority \
        lichtfeld_studio_el9.sif

%post
    set -eu

    dnf -y update
    dnf -y install dnf-plugins-core epel-release

    # Enable CRB for development packages on EL9
    dnf config-manager --set-enabled crb
    dnf config-manager --add-repo https://developer.download.nvidia.com/compute/cuda/repos/rhel9/x86_64/cuda-rhel9.repo

    dnf -y install \
        gcc \
        gcc-c++ \
        gcc-toolset-14-gcc \
        gcc-toolset-14-gcc-c++ \
        gcc-toolset-14-gcc-gfortran \
        make \
        nasm \
        autoconf \
        autoconf-archive \
        automake \
        libtool \
        git \
        zip \
        unzip \
        tar \
        pkgconf-pkg-config \
        perl \
        python3 \
        python3-pip \
        which \
        file \
        mesa-libGL \
        mesa-libGL-devel \
        mesa-libGLU-devel \
        mesa-libEGL \
        mesa-libEGL-devel \
        libglvnd-devel \
        libX11 \
        libX11-devel \
        libXext \
        libXext-devel \
        libXft \
        libXft-devel \
        libXrandr \
        libXinerama \
        libXcursor \
        libXi \
        wayland-devel \
        wayland-protocols-devel \
        ibus \
        ibus-devel \
        libxkbcommon \
        libxkbcommon-devel \
        libxcb \
        xcb-util \
        xcb-util-image \
        xcb-util-keysyms \
        xcb-util-renderutil \
        xcb-util-wm \
        cuda-toolkit-12-8


    # Rocky/RHEL package naming differs across mirrors; support both variants.
    if ! dnf -y install ninja-build; then
        dnf -y install ninja
    fi
    if ! command -v ninja >/dev/null 2>&1 && command -v ninja-build >/dev/null 2>&1; then
        ln -sf "$(command -v ninja-build)" /usr/local/bin/ninja
    fi

    export GCC_TOOLSET_ROOT=/opt/rh/gcc-toolset-14/root/usr
    export PATH="${GCC_TOOLSET_ROOT}/bin:/usr/local/bin:/usr/local/cuda/bin:$PATH"
    export LD_LIBRARY_PATH="${GCC_TOOLSET_ROOT}/lib64:${LD_LIBRARY_PATH:-}"
    export CC="${GCC_TOOLSET_ROOT}/bin/gcc"
    export CXX="${GCC_TOOLSET_ROOT}/bin/g++"
    export FC="${GCC_TOOLSET_ROOT}/bin/gfortran"
    export CUDAHOSTCXX="${GCC_TOOLSET_ROOT}/bin/g++"

    curl -fsSL https://ftp.gnu.org/gnu/autoconf/autoconf-2.71.tar.gz -o /var/tmp/autoconf-2.71.tar.gz
    tar -xf /var/tmp/autoconf-2.71.tar.gz -C /var/tmp
    cd /var/tmp/autoconf-2.71
    ./configure --prefix=/usr/local
    make -j"$(nproc)"
    make install
    cd /
    rm -rf /var/tmp/autoconf-2.71 /var/tmp/autoconf-2.71.tar.gz
    export PATH="${GCC_TOOLSET_ROOT}/bin:/usr/local/bin:/usr/local/cuda/bin:$PATH"

    python3 -m pip install --no-cache-dir "cmake>=3.30,<4"

    dnf clean all
    rm -rf /var/cache/dnf

    git clone https://github.com/microsoft/vcpkg.git /opt/vcpkg
    if [ -n "${VCPKG_DOWNLOADS:-}" ]; then
        mkdir -p "$VCPKG_DOWNLOADS"
    fi
    if [ -n "${VCPKG_DEFAULT_BINARY_CACHE:-}" ]; then
        mkdir -p "$VCPKG_DEFAULT_BINARY_CACHE"
    fi
    /opt/vcpkg/bootstrap-vcpkg.sh -disableMetrics

    git clone --depth 1 --recursive https://github.com/MrNeRF/LichtFeld-Studio /opt/LichtFeld-Studio

    export VCPKG_ROOT=/opt/vcpkg
    cmake -S /opt/LichtFeld-Studio -B /opt/LichtFeld-Studio/build \
        -G Ninja \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_C_COMPILER="${GCC_TOOLSET_ROOT}/bin/gcc" \
        -DCMAKE_CXX_COMPILER="${GCC_TOOLSET_ROOT}/bin/g++" \
        -DCMAKE_CUDA_COMPILER=/usr/local/cuda/bin/nvcc \
        -DCMAKE_CUDA_HOST_COMPILER="${GCC_TOOLSET_ROOT}/bin/g++" \
        -DCMAKE_CUDA_ARCHITECTURES=86 \
        -DBUILD_PYTHON_STUBS=OFF \
        -DCMAKE_TOOLCHAIN_FILE=/opt/vcpkg/scripts/buildsystems/vcpkg.cmake

    cmake --build /opt/LichtFeld-Studio/build --parallel "$(nproc)"
    cmake --install /opt/LichtFeld-Studio/build --prefix /opt/lichtfeld

    ln -sf /opt/LichtFeld-Studio/build/LichtFeld-Studio /usr/local/bin/lichtfeld-studio

%runscript
    export QT_X11_NO_MITSHM=${QT_X11_NO_MITSHM:-1}
    export LD_LIBRARY_PATH=/opt/LichtFeld-Studio/build:/opt/lichtfeld/lib64:/opt/lichtfeld/lib:${LD_LIBRARY_PATH:-}
    exec /opt/LichtFeld-Studio/build/LichtFeld-Studio "$@"

%test
    set -eu
    test -x /opt/LichtFeld-Studio/build/LichtFeld-Studio
    ldd /opt/LichtFeld-Studio/build/LichtFeld-Studio >/dev/null
