Bootstrap: docker
From: colmap/colmap:latest

%labels
    Description Simple COLMAP + pycolmap-cuda12 image built from colmap/colmap Docker image

%environment
    export PYTHONNOUSERSITE=1

%post
    set -eu

    apt-get update

    # ONNX Runtime's CUDA provider in this image depends on libcudnn.so.9.
    # Install the cuDNN 9 runtime from the NVIDIA CUDA repo already configured
    # in the base image so ALIKED / LightGlue can use GPU execution.
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends libcudnn9-cuda-12

    # Ensure pip exists, then install pycolmap-cuda12 only if pycolmap is missing.
    if ! command -v python3 >/dev/null 2>&1; then
        DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends python3 python3-pip
    elif ! command -v pip3 >/dev/null 2>&1; then
        DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends python3-pip
    fi

    if ! python3 -c "import pycolmap" >/dev/null 2>&1; then
        PIP_BREAK_FLAG=""
        if python3 -m pip install --help 2>/dev/null | grep -q -- '--break-system-packages'; then
            PIP_BREAK_FLAG="--break-system-packages"
        fi

        # Avoid upgrading distro-managed pip (can fail on Debian/Ubuntu images).
        python3 -m pip install --no-cache-dir ${PIP_BREAK_FLAG} pycolmap-cuda12
    fi

    rm -rf /var/lib/apt/lists/*

%test
    set -e
    colmap -h >/dev/null
    python3 -c "import pycolmap; print('pycolmap OK')"
